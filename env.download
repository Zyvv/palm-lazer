# ─────────────────────────────────────────────────────────────────────────────
# Palm Lazer — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Palm Lazer
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_PRODUCT_SOURCE=palm_lazer

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Anon/public key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Groq ──────────────────────────────────────────────────────────────────────
# One key per project convention — get from console.groq.com
GROQ_API_KEY=

# ── Resend ────────────────────────────────────────────────────────────────────
# API key — from resend.com dashboard
RESEND_API_KEY=
# Verified sending domain — must match your Resend domain config
RESEND_FROM_EMAIL=
# Webhook signing secret — from Resend dashboard → Webhooks
RESEND_WEBHOOK_SECRET=

# ── Cron ─────────────────────────────────────────────────────────────────────
# Secret header value Vercel sends with cron requests — generate a random string
CRON_SECRET=

# ── ZYVV bridge ───────────────────────────────────────────────────────────────
# Base URL of the ZYVV product — same Supabase instance, different frontend
ZYVV_APP_URL=

# ── Python FastAPI ────────────────────────────────────────────────────────────
# Internal URL of the FastAPI stub — used by Next.js API routes to call Python
PYTHON_API_URL=
# Shared secret between Next.js and FastAPI
PYTHON_API_SECRET=

# ── OG Image ─────────────────────────────────────────────────────────────────
# Used in app/api/og/route.ts for dynamic share image generation
OG_IMAGE_SECRET=
